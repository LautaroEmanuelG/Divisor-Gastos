---
export const prerender = false;

import { getRedisClient } from '../lib/redis';

const LOCALHOST_HOSTNAMES = new Set(['localhost', '127.0.0.1', '::1']);
const isLocalPreview =
  LOCALHOST_HOSTNAMES.has(Astro.url.hostname) ||
  Astro.url.hostname.endsWith('.localhost');

if (!isLocalPreview) {
  return new Response('Not found', { status: 404 });
}

const requestedId = (Astro.url.searchParams.get('id') ?? '').trim();
const isValidId = /^[a-z0-9]{4,10}$/.test(requestedId);
const DEFAULT_PREVIEW_ID = 'abc123';

const escapeSvgText = (value: string) =>
  value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&apos;');

const buildPreviewSvg = (input: {
  title: string;
  description: string;
  amountLabel: string;
  emojiLine: string;
}) => {
  const title = escapeSvgText(input.title);
  const description = escapeSvgText(input.description);
  const amountLabel = escapeSvgText(input.amountLabel);
  const emojiLine = escapeSvgText(input.emojiLine);

  return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(`
    <svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
      <defs>
        <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#ffffff"/>
          <stop offset="45%" stop-color="#f4f1ff"/>
          <stop offset="100%" stop-color="#e9e3ff"/>
        </linearGradient>
        <linearGradient id="badge" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#6c5ce7"/>
          <stop offset="100%" stop-color="#a29bfe"/>
        </linearGradient>
        <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="18" stdDeviation="22" flood-color="#6c5ce7" flood-opacity="0.18"/>
        </filter>
      </defs>
      <rect width="1200" height="630" fill="url(#bg)"/>
      <circle cx="1035" cy="85" r="165" fill="#6c5ce722"/>
      <circle cx="140" cy="560" r="145" fill="#a29bfe1f"/>
      <rect x="48" y="42" width="1104" height="546" rx="34" fill="rgba(255,255,255,0.92)" stroke="#e4e0f8" stroke-width="2" filter="url(#shadow)"/>
      <rect x="84" y="82" width="300" height="48" rx="24" fill="#ece9fd" stroke="#d6cffb"/>
      <text x="234" y="114" text-anchor="middle" fill="#6c5ce7" font-family="Arial, Helvetica, sans-serif" font-size="18" font-weight="800" letter-spacing="2">OPEN GRAPH PREVIEW</text>
      <text x="84" y="224" fill="#1e1b3a" font-family="Arial, Helvetica, sans-serif" font-size="68" font-weight="800" letter-spacing="-2">${title}</text>
      <text x="84" y="278" fill="#6f6b91" font-family="Arial, Helvetica, sans-serif" font-size="24">${description}</text>
      <rect x="84" y="330" width="248" height="62" rx="20" fill="#ffffff" stroke="#e4e0f8"/>
      <text x="110" y="370" fill="#6c5ce7" font-family="Arial, Helvetica, sans-serif" font-size="26" font-weight="800">${emojiLine}</text>
      <rect x="84" y="430" width="300" height="78" rx="22" fill="url(#badge)"/>
      <text x="234" y="478" text-anchor="middle" fill="#ffffff" font-family="Arial, Helvetica, sans-serif" font-size="32" font-weight="800">${amountLabel}</text>
      <text x="84" y="548" fill="#7c7a9a" font-family="Arial, Helvetica, sans-serif" font-size="18">Comparte la sesión y la tarjeta se verá igual en WhatsApp, Facebook y LinkedIn.</text>
    </svg>
  `)}`;
};

const FALLBACK_TITLE = 'La Jodita 150... :$ 💸 🍻 🧉';
const FALLBACK_DESCRIPTION =
  'Vista previa demo de la tarjeta compartida para La Jodita.';
const FALLBACK_AMOUNT = '150...';
const FALLBACK_EMOJIS = '💸 🍻 🧉';

let previewId = DEFAULT_PREVIEW_ID;
let previewTitle = FALLBACK_TITLE;
let previewDescription = FALLBACK_DESCRIPTION;
let previewAmountLabel = FALLBACK_AMOUNT;
let previewEmojiLine = FALLBACK_EMOJIS;
let previewImage = buildPreviewSvg({
  title: previewTitle,
  description: previewDescription,
  amountLabel: previewAmountLabel,
  emojiLine: previewEmojiLine,
});
let previewTarget = `/s/${DEFAULT_PREVIEW_ID}`;

if (isValidId) {
  previewId = requestedId;
  try {
    const redis = await getRedisClient();
    const raw = await redis.get<string>(`s:${requestedId}`);

    if (raw) {
      const parsed = JSON.parse(raw) as Record<string, unknown>;
      const tripName =
        typeof parsed.tripName === 'string' ? parsed.tripName.trim() : '';
      const participantCount = Array.isArray(parsed.participants)
        ? parsed.participants.length
        : 0;
      const expenseCount = Array.isArray(parsed.expenses)
        ? parsed.expenses.length
        : 0;
      previewTitle = tripName
        ? `${tripName} · Preview`
        : `Preview de sesión ${requestedId}`;
      previewDescription =
        participantCount > 0
          ? `${participantCount} personas, ${expenseCount} gastos y la tarjeta lista para compartir.`
          : 'Vista previa de la tarjeta que se compartirá para esa sesión.';
      previewAmountLabel = 'Sesión real';
      previewEmojiLine = '💸 🍻 🧉';
      previewImage = `/api/og/${requestedId}.png`;
      previewTarget = `/s/${requestedId}`;
    } else {
      previewTitle = FALLBACK_TITLE;
      previewDescription = FALLBACK_DESCRIPTION;
      previewTarget = `/open-graph?id=${DEFAULT_PREVIEW_ID}`;
    }
  } catch {
    previewTitle = FALLBACK_TITLE;
    previewDescription = FALLBACK_DESCRIPTION;
    previewTarget = `/open-graph?id=${DEFAULT_PREVIEW_ID}`;
  }
} else if (requestedId) {
  previewTarget = `/open-graph?id=${DEFAULT_PREVIEW_ID}`;
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <title>{previewTitle} | La Jodita</title>
    <meta
      name="description"
      content={previewDescription}
    />
    <meta
      name="robots"
      content="noindex, nofollow"
    />
    <meta
      property="og:type"
      content="website"
    />
    <meta
      property="og:site_name"
      content="La Jodita"
    />
    <meta
      property="og:title"
      content={previewTitle}
    />
    <meta
      property="og:description"
      content={previewDescription}
    />
    <meta
      property="og:image"
      content={previewImage}
    />
    <meta
      property="og:image:width"
      content="1200"
    />
    <meta
      property="og:image:height"
      content="630"
    />
    <meta
      property="og:locale"
      content="es_AR"
    />
    <meta
      name="twitter:card"
      content="summary_large_image"
    />
    <meta
      name="twitter:title"
      content={previewTitle}
    />
    <meta
      name="twitter:description"
      content={previewDescription}
    />
    <meta
      name="twitter:image"
      content={previewImage}
    />
    <meta
      name="theme-color"
      content="#6c5ce7"
    />
    <link
      rel="icon"
      href="/icon/la-jodita.svg"
      type="image/svg+xml"
    />
    <style>
      :root {
        color-scheme: light;
        --bg: #f0eeff;
        --surface: rgba(255, 255, 255, 0.92);
        --surface-strong: #ffffff;
        --border: #e4e0f8;
        --text: #1e1b3a;
        --muted: #6f6b91;
        --accent: #6c5ce7;
        --accent-light: #ece9fd;
        --shadow: 0 20px 60px rgba(108, 92, 231, 0.16);
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        min-height: 100%;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text);
        background:
          radial-gradient(
            circle at top left,
            #ffffff 0,
            #f4f1ff 26%,
            transparent 26%
          ),
          radial-gradient(
            circle at bottom right,
            #ddd7ff 0,
            #f0eeff 32%,
            transparent 32%
          ),
          var(--bg);
      }
      .wrap {
        max-width: 1180px;
        margin: 0 auto;
        padding: 28px 20px 40px;
      }
      .hero {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 24px;
        align-items: stretch;
      }
      .panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 28px;
        box-shadow: var(--shadow);
        overflow: hidden;
      }
      .copy {
        padding: 28px;
      }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        background: var(--accent-light);
        border: 1px solid #d6cffb;
        border-radius: 999px;
        padding: 8px 12px;
      }
      h1 {
        margin: 18px 0 12px;
        font-size: clamp(30px, 4vw, 56px);
        line-height: 0.98;
        letter-spacing: -0.04em;
      }
      p {
        margin: 0 0 16px;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.6;
      }
      .controls {
        display: grid;
        gap: 12px;
        margin-top: 22px;
      }
      .field {
        display: grid;
        gap: 8px;
      }
      label {
        font-size: 12px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      input {
        width: 100%;
        border: 1.5px solid var(--border);
        background: var(--surface-strong);
        color: var(--text);
        border-radius: 14px;
        padding: 14px 16px;
        font: inherit;
        outline: none;
      }
      input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(108, 92, 231, 0.12);
      }
      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 8px;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-radius: 12px;
        padding: 12px 16px;
        border: 1.5px solid transparent;
        text-decoration: none;
        font-weight: 700;
        transition:
          transform 0.2s,
          border-color 0.2s,
          background 0.2s;
      }
      .btn:hover {
        transform: translateY(-1px);
      }
      .btn.primary {
        background: var(--accent);
        color: white;
      }
      .btn.secondary {
        background: var(--accent-light);
        color: var(--accent);
        border-color: #d6cffb;
      }
      .preview {
        display: flex;
        flex-direction: column;
      }
      .preview-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 18px 20px;
        border-bottom: 1px solid var(--border);
        background: rgba(247, 245, 255, 0.82);
      }
      .preview-title {
        display: grid;
        gap: 4px;
      }
      .preview-title strong {
        font-size: 15px;
      }
      .preview-title span {
        font-size: 13px;
        color: var(--muted);
      }
      .frame {
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 520px;
        background: linear-gradient(
          135deg,
          rgba(108, 92, 231, 0.08),
          rgba(162, 155, 254, 0.06)
        );
      }
      .frame img {
        width: 100%;
        max-width: 100%;
        border-radius: 22px;
        border: 1px solid rgba(108, 92, 231, 0.15);
        box-shadow: 0 18px 48px rgba(30, 27, 58, 0.12);
        background: white;
      }
      .frame-fallback {
        width: 100%;
        aspect-ratio: 1200 / 630;
        border-radius: 22px;
        border: 1px solid rgba(108, 92, 231, 0.15);
        box-shadow: 0 18px 48px rgba(30, 27, 58, 0.12);
        background: radial-gradient(
          circle at 15% 20%,
          #ffffff 0%,
          #f1eeff 40%,
          #e9e3ff 100%
        );
        padding: 28px;
        display: grid;
        align-content: center;
        gap: 22px;
      }
      .frame-fallback .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        border-radius: 999px;
        padding: 8px 14px;
        background: #ece9fd;
        border: 1px solid #d6cffb;
        color: var(--accent);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .frame-fallback h2 {
        margin: 0;
        font-size: clamp(30px, 4vw, 58px);
        line-height: 0.98;
        letter-spacing: -0.04em;
        color: var(--text);
      }
      .frame-fallback .sub {
        margin: 0;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.55;
      }
      .frame-fallback .amount {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        padding: 14px 18px;
        border-radius: 18px;
        background: #6c5ce7;
        color: white;
        font-size: 30px;
        font-weight: 800;
        letter-spacing: -0.03em;
        box-shadow: 0 12px 28px rgba(108, 92, 231, 0.2);
      }
      .meta {
        display: grid;
        gap: 10px;
        margin-top: 16px;
        padding: 16px 18px;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 14px;
      }
      code {
        background: #f7f5ff;
        border: 1px solid #e4e0f8;
        padding: 2px 6px;
        border-radius: 8px;
        color: var(--text);
      }
      @media (max-width: 920px) {
        .hero {
          grid-template-columns: 1fr;
        }
        .frame {
          min-height: auto;
        }
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="hero">
        <div class="panel copy">
          <span class="eyebrow">Open Graph Preview</span>
          <h1>Vista previa de la tarjeta que se comparte</h1>
          <p>
            Acá podés ver exactamente cómo se verá la card al compartir La
            Jodita. Si querés probar una sesión real, pasale un <code>id</code> en
            la URL.
          </p>
          <p>
            Ejemplo: <code>/open-graph?id=abc123</code>
          </p>

          <form
            class="controls"
            method="get"
            action="/open-graph">
            <div class="field">
              <label for="id">ID de sesión</label>
              <input
                id="id"
                name="id"
                type="text"
                placeholder="abc123"
                value={previewId}
                maxlength="10"
                autocomplete="off"
              />
            </div>
            <div class="actions">
              <button
                class="btn primary"
                type="submit"
                >Ver preview</button
              >
              <a
                class="btn secondary"
                href="/open-graph"
                >Ver card default</a
              >
              <a
                class="btn secondary"
                href={previewImage}
                target="_blank"
                rel="noreferrer"
                >Abrir PNG</a
              >
            </div>
          </form>

          <div class="meta">
            <div><strong>Imagen:</strong> <code>{previewImage}</code></div>
            <div>
              <strong>Ruta compartida:</strong>
              <code>{previewTarget}</code>
            </div>
            <div>
              <strong>Consejo:</strong> si no ves una sesión real, primero crea una
              y luego pega su ID acá.
            </div>
          </div>
        </div>

        <aside class="panel preview">
          <div class="preview-head">
            <div class="preview-title">
              <strong>{previewTitle}</strong>
              <span>{previewDescription}</span>
            </div>
            <a
              class="btn secondary"
              href={previewTarget}
              target="_blank"
              rel="noreferrer"
              >Abrir destino</a
            >
          </div>
          <div class="frame">
            {
              previewImage.startsWith('data:image/svg+xml') ? (
                <div class="frame-fallback">
                  <span class="badge">Open Graph Preview</span>
                  <h2>{previewTitle}</h2>
                  <p class="sub">{previewDescription}</p>
                  <div class="amount">{previewAmountLabel}</div>
                  <p class="sub">{previewEmojiLine}</p>
                </div>
              ) : (
                <img
                  src={previewImage}
                  alt={previewTitle}
                />
              )
            }
          </div>
        </aside>
      </section>
    </main>
  </body>
</html>
