# ---------------------------------------------------------------------------
# dev-bitrix — variables de entorno
# Copiar este archivo a `.env.local` (con el punto) y completar los valores.
# .env.local NUNCA se commitea — agregarlo a .gitignore.
# ---------------------------------------------------------------------------

# === REQUERIDAS ============================================================

# Token del Cloudflare Tunnel.
# Obtener en: Cloudflare Zero Trust → Networks → Tunnels → (tu tunnel) → Configure → Token
CLOUDFLARE_TUNNEL_TOKEN=


# === OPCIONALES DEL SCRIPT =================================================

# URL pública del tunnel. Solo se imprime al arrancar (informativo).
# TUNNEL_URL=https://dev.moreclix.co

# Puerto local del dev server. Debe coincidir con la regla en Cloudflare.
# Default: según framework (Next/CRA/Nuxt/Remix=3000, Vite=5173, Astro=4321)
# DEV_PORT=3000

# Override del comando de dev (para proyectos sin framework detectable).
# DEV_COMMAND=node server.js
# DEV_COMMAND=deno task dev
# DEV_COMMAND=bun run start

# Path al binario de cloudflared si no está en PATH ni ubicaciones standard.
# CLOUDFLARED_BIN=/usr/local/bin/cloudflared

# Si =1, NO arranca el dev server (solo el tunnel).
# Útil si el dev server ya corre en otra terminal.
# TUNNEL_ONLY=0


# === FLAGS DE LA APP (según framework) =====================================
# Activan la carga del SDK de Bitrix24 en el Bootstrap component.
# Solo descomentar UNO según el framework del proyecto.

# Next.js
# NEXT_PUBLIC_ENABLE_BITRIX=1

# Vite (React, Vue, Svelte)
# VITE_ENABLE_BITRIX=1

# Create React App
# REACT_APP_ENABLE_BITRIX=1

# Nuxt
# NUXT_PUBLIC_ENABLE_BITRIX=1

# Astro
# PUBLIC_ENABLE_BITRIX=1
